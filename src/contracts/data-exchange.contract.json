      "banks",
      "mandatory_sb_reporters"
    ]
  },
  "queries": {
    "identifiers": [
      "cedula",
      "ruc",
      "codigo_sb"
    ],
    "products": [
      "basic_report",
      "complete_report"
    ],
    "channels": [
      "individual",
      "batch",
      "api"
    ],
    "auditRequired": [
      "bac",
      "consent",
      "user",
      "channel",
      "ip",
      "product",
      "tariff",
      "estimatedValue",
      "status"
    ]
  },
  "phase1Endpoints": [
    {
      "method": "GET",
      "path": "/contracts/v1",
      "status": "implemented_contract_only"
    },
    {
      "method": "POST",
      "path": "/api/v1/auth/login",
      "status": "reserved_phase_2"
    },
    {
      "method": "POST",
      "path": "/api/v1/auth/client-registration",
