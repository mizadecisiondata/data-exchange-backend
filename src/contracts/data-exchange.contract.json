  },
  "commercialModes": [
    "Cliente Normal",
    "Data Partner Contributor",
    "Data Partner Active",
    "Data Partner Founding"
  ],
  "decisionCredits": {
    "Cliente Normal": {
      "earnsCredits": false,
      "excessTariff": "cliente_normal"
    },
    "Data Partner Contributor": {
      "basicQueryRatio": "1:2",
      "excessTariff": "cliente_normal"
    },
    "Data Partner Active": {
      "preferentialRatio": "1:1",
      "excessTariff": "cliente_normal"
    },
    "Data Partner Founding": {
      "preferentialRatio": "1:1",
      "excessTariff": "cliente_normal"
    }
  },
  "billing": {
    "primaryModel": "monthly_postpaid",
