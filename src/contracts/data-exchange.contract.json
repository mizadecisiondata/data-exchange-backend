      "codigo_sb"
    ],
    "products": [
      "basic_report",
      "complete_report"
    ],
    "channels": [
      "individual",
      "batch",
      "api"
    ],
    "auditRequired": [
      "bac",
      "consent",
      "user",
      "channel",
      "ip",
      "product",
      "tariff",
      "estimatedValue",
      "status"
    ]
