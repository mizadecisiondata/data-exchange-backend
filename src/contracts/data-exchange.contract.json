{
  "version": "0.2.0-phase-1-contract",
  "status": "source_backed_guardrails_only",
  "service": "data-exchange-backend",
  "phase": "1-contracts",
  "portals": {
    "client": "separate_client_portal",
    "admin": "separate_admin_portal",
