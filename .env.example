NODE_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=4100
SERVICE_NAME=data-exchange-backend

DATABASE_URL=postgres://data_exchange:data_exchange@localhost:5432/data_exchange
REDIS_URL=redis://localhost:6379/0
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=data-exchange-local

JWT_SECRET=replace-with-local-secret
API_KEY_PEPPER=replace-with-local-pepper

INGESTION_QUALITY_THRESHOLD=0.95
BILLING_MODE=monthly_postpaid
ALLOW_PREPAID_PRIMARY_MODEL=false
BAC_APPEND_ONLY=true
